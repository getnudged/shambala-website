---
import '../styles/components/nav.css';
---

<header class="site-header" data-site-header>
  <a class="site-logo" href="/" aria-label="Shambala Holistic and Retreat Centre homepage">
    Shambala <span>Holistic & Retreat Centre</span>
  </a>
  <nav class="primary-nav" aria-label="Primary navigation">
    <a href="/">Welcome</a>
    <a href="/about/">About</a>
    <div class="nav-dropdown">
      <a href="/therapies/" aria-haspopup="true">Therapies</a>
      <div class="nav-dropdown__menu" aria-label="Therapies pages">
        <a href="/therapies/holistic/">Holistic</a>
        <a href="/therapies/massage/">Massage</a>
        <a href="/therapies/training/">Training</a>
        <a href="/wellness-days/">Wellness Days</a>
      </div>
    </div>
    <a href="/retreats/">Retreats</a>
    <a href="/sound-baths-yoga/">Sound & Yoga</a>
    <a href="/corporate-wellness/">Corporate</a>
    <a href="/self-catering/">Stay</a>
    <a href="/contact/">Contact</a>
  </nav>
  <a class="nav-cta" href="/contact/">Book a Session</a>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  if (header) {
    const updateHeader = () => {
      header.classList.toggle('site-header--scrolled', window.scrollY > 60);
    };
    updateHeader();
    window.addEventListener('scroll', updateHeader, { passive: true });
  }
</script>
