---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/components/inner-pages.css';

export async function getStaticPaths() {
  const retreats = await getCollection('retreats');

  return retreats.map((retreat) => ({
    params: { slug: retreat.data.slug ?? retreat.id.replace(/\.md$/, '') },
    props: { retreat }
  }));
}

const { retreat } = Astro.props;
const { Content } = await render(retreat);
const slug = retreat.data.slug ?? retreat.id.replace(/\.md$/, '');
const canonical = `https://shambalaholisticandretreatcentre.com/retreats/${slug}/`;
const allRetreats = await getCollection('retreats');
const mapsUrl = 'https://maps.google.com/?q=48%20Geaglum%20Road%2C%20Derrylin%2C%20Co.%20Fermanagh%2C%20BT92%209GN';
const hasPoster = Boolean(retreat.data.posterImage || retreat.data.posterPdf);
const posterPreviewTarget = `retreat-poster-${slug}`;
const posterAlt = retreat.data.posterAlt ?? `${retreat.data.title} poster at Shambala Holistic Retreat Centre, Derrylin, Co. Fermanagh`;

const formatDate = (date?: Date) =>
  date
    ? date.toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      })
    : null;

const dateLabel = retreat.data.startDate
  ? retreat.data.endDate && retreat.data.endDate.valueOf() !== retreat.data.startDate.valueOf()
    ? `${formatDate(retreat.data.startDate)} - ${formatDate(retreat.data.endDate)}`
    : formatDate(retreat.data.startDate)
  : retreat.data.dateNote ?? (retreat.data.year ? `${retreat.data.year} date to confirm` : 'Date to confirm');

const priceLabel = retreat.data.priceEUR
  ? `£${retreat.data.price} / €${retreat.data.priceEUR}`
  : `£${retreat.data.price}`;

const depositLabel = retreat.data.price >= 200
  ? retreat.data.priceEUR
    ? 'Typical weekend retreat deposit: £130 / €150'
    : 'Typical weekend retreat deposit: £130'
  : retreat.data.priceEUR
    ? 'Typical half-day retreat deposit: £20 / €23'
    : 'Typical half-day retreat deposit: £20';

const relatedRetreats = allRetreats
  .filter((item) => (item.data.slug ?? item.id.replace(/\.md$/, '')) !== slug)
  .sort((a, b) => {
    const aTime = a.data.startDate?.valueOf() ?? Number.MAX_SAFE_INTEGER;
    const bTime = b.data.startDate?.valueOf() ?? Number.MAX_SAFE_INTEGER;
    return aTime - bTime;
  })
  .slice(0, 2);

const buildDescription = (description: string) => {
  const suffix = ' Join Shambala in Derrylin, Co. Fermanagh for retreat time beside Upper Lough Erne.';
  const text = description.length >= 150 ? description : `${description}${suffix}`;
  if (text.length <= 160) return text;
  const trimmed = text.slice(0, 157);
  return `${trimmed.slice(0, trimmed.lastIndexOf(' '))}...`;
};

const meta = {
  title: `${retreat.data.title} | Shambala Fermanagh`,
  description: buildDescription(retreat.data.description),
  canonical
};

const eventSchema = retreat.data.startDate
  ? {
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: retreat.data.title,
      description: retreat.data.description,
      startDate: retreat.data.startDate.toISOString().slice(0, 10),
      endDate: (retreat.data.endDate ?? retreat.data.startDate).toISOString().slice(0, 10),
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      eventStatus: 'https://schema.org/EventScheduled',
      location: {
        '@type': 'Place',
        name: 'Shambala Holistic & Retreat Centre',
        address: {
          '@type': 'PostalAddress',
          streetAddress: '48 Geaglum Road',
          addressLocality: 'Derrylin',
          addressRegion: 'Co. Fermanagh',
          postalCode: 'BT92 9GN',
          addressCountry: 'GB'
        }
      },
      offers: {
        '@type': 'Offer',
        price: retreat.data.price,
        priceCurrency: retreat.data.currency,
        availability: 'https://schema.org/InStock',
        url: canonical
      },
      organizer: {
        '@type': 'Organization',
        name: 'Shambala Holistic & Retreat Centre',
        url: 'https://shambalaholisticandretreatcentre.com/'
      }
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: retreat.data.title,
      url: canonical,
      description: retreat.data.description
    };
---

<BaseLayout {meta} schema={eventSchema}>
  <article>
    <header class="inner-hero inner-hero--retreat-detail">
      <div class="inner-hero__content">
        <div class="retreat-hero-card">
          <p class="label">Retreat at Shambala · {dateLabel}</p>
          <h1>{retreat.data.title}</h1>
          <p>{retreat.data.description}</p>
          <div class="retreat-hero-meta" aria-label="Retreat summary">
            <span>{priceLabel}</span>
            <span>{retreat.data.facilitators.length > 0 ? retreat.data.facilitators.join(' & ') : 'Facilitator to confirm'}</span>
            <span>Derrylin, Co. Fermanagh</span>
          </div>
        </div>
      </div>
    </header>

    <section class="page-section">
      <div class="retreat-detail-grid">
        <aside class="retreat-facts" aria-label="Retreat details">
          <p class="label">Retreat Details</p>
          <dl>
            <div>
              <dt>Date</dt>
              <dd>{dateLabel}</dd>
            </div>
            <div>
              <dt>Price</dt>
              <dd>{priceLabel}</dd>
            </div>
            {retreat.data.facilitators.length > 0 && (
              <div>
                <dt>Facilitators</dt>
                <dd>{retreat.data.facilitators.join(', ')}</dd>
              </div>
            )}
          </dl>
          {!retreat.data.startDate && <p class="detail-placeholder">Placeholder: exact retreat dates to confirm before launch.</p>}
          <a class="btn btn-dark" href="#retreat-enquiry">Reserve Your Place</a>
        </aside>

        <div class="article-content">
          <Content />
        </div>
      </div>
    </section>

    <section class="page-section page-section--mist">
      <div class="section-heading section-heading--simple">
        <p class="label">Pricing & Booking</p>
        <h2>Price, Deposit and Booking Notes</h2>
      </div>
      <div class="retreat-pricing-grid">
        <article>
          <p class="label">Retreat Price</p>
          <h3>{priceLabel}</h3>
          <p>Listed retreat price for {retreat.data.title}. Contact Shambala to confirm current availability before arranging travel.</p>
        </article>
        <article>
          <p class="label">Deposit</p>
          <h3>{depositLabel}</h3>
          <p>Deposits are described in the audit notes as optional, with priority given to confirmed bookings.</p>
        </article>
        <article>
          <p class="label">Cancellation</p>
          <h3>14-day policy</h3>
          <p>Audit notes say deposits are fully refundable up to 14 days before the retreat, then transferable to a future retreat.</p>
        </article>
      </div>
      {!retreat.data.startDate && <p class="small-note">Placeholder: exact date-dependent booking terms should be reviewed once dates are confirmed.</p>}
    </section>

    {hasPoster && (
      <section class="page-section">
        <div class="split-layout">
          <div>
            <p class="label">Retreat Poster</p>
            <h2>Preview the Retreat Poster</h2>
            <p>Open the poster for a quick visual summary of dates, pricing and included retreat activities.</p>
          </div>
          <div class="poster-preview-card">
            {retreat.data.posterImage ? (
              <a class="poster-preview-card__image" href={`#${posterPreviewTarget}`} aria-label={`Preview poster for ${retreat.data.title}`}>
                <img src={retreat.data.posterImage} alt={posterAlt} loading="lazy" />
              </a>
            ) : (
              <a class="poster-preview-card__pdf" href={`#${posterPreviewTarget}`} aria-label={`Preview poster for ${retreat.data.title}`}>
                <span class="label">PDF Poster</span>
                <strong>{retreat.data.title}</strong>
              </a>
            )}
            <div class="poster-preview-card__actions">
              <a class="btn btn-dark" href={`#${posterPreviewTarget}`}>Preview Poster</a>
              {retreat.data.posterPdf && <a class="btn btn-ghost" href={retreat.data.posterPdf} target="_blank" rel="noreferrer">Open PDF</a>}
            </div>
          </div>
        </div>

        <div class="poster-modal" id={posterPreviewTarget} role="dialog" aria-modal="true" aria-label={`Poster preview for ${retreat.data.title}`}>
          <a class="poster-modal__backdrop" href="#retreat-enquiry" aria-label="Close poster preview"></a>
          <div class="poster-modal__content">
            <a class="poster-modal__close" href="#retreat-enquiry">Close</a>
            {retreat.data.posterPdf && !retreat.data.posterImage ? (
              <iframe src={retreat.data.posterPdf} title={`Poster PDF for ${retreat.data.title}`}></iframe>
            ) : (
              <img src={retreat.data.posterImage} alt={posterAlt} loading="lazy" />
            )}
          </div>
        </div>
      </section>
    )}

    <section class="page-section">
      <div class="section-heading section-heading--simple">
        <p class="label">What's Included</p>
        <h2>Included in This Retreat</h2>
      </div>
      <div class="value-grid">
        {retreat.data.includes.map((item) => (
          <article>
            <h3>{item}</h3>
            <p>Included as part of {retreat.data.title} at Shambala Holistic & Retreat Centre.</p>
          </article>
        ))}
      </div>
      {retreat.data.includes.length === 0 && <p class="detail-placeholder">Placeholder: add confirmed inclusions for this retreat.</p>}
    </section>

    <section class="page-section page-section--mist">
      <div class="split-layout">
        <div>
          <p class="label">Facilitators</p>
          <h2>Who Holds the Retreat</h2>
        </div>
        <div class="copy-flow">
          {retreat.data.facilitators.length > 0 ? (
            <>
              <p>This retreat is currently listed with {retreat.data.facilitators.join(' and ')} as facilitator{retreat.data.facilitators.length > 1 ? 's' : ''}.</p>
              <p>Facilitator details should be confirmed when final retreat dates are agreed.</p>
            </>
          ) : (
            <p class="detail-placeholder">Placeholder: facilitator details to confirm from Shambala before launch.</p>
          )}
        </div>
      </div>
    </section>

    <section class="page-section" id="retreat-enquiry">
      <div class="split-layout">
        <div>
          <p class="label">Retreat Enquiry</p>
          <h2>Reserve Your Place</h2>
          <p>Use this retreat enquiry form to contact Shambala about availability, dietary requirements and booking details.</p>
        </div>
        <form class="enquiry-form" name={`retreat-${slug}`} method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value={`retreat-${slug}`} />
          <input type="hidden" name="retreat" value={retreat.data.title} />
          <label>
            <span>Name</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>
          <label>
            <span>Email</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>
          <label>
            <span>Phone</span>
            <input name="phone" type="tel" autocomplete="tel" />
          </label>
          <label>
            <span>Number of guests</span>
            <input name="guests" type="number" min="1" inputmode="numeric" />
          </label>
          <label class="enquiry-form__full">
            <span>Dietary requirements</span>
            <textarea name="dietary-requirements" rows="3"></textarea>
          </label>
          <label class="enquiry-form__full">
            <span>Message</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <label class="enquiry-form__full">
            <span>How did you hear about us?</span>
            <input name="referral-source" type="text" />
          </label>
          <button class="btn btn-primary" type="submit">Send Retreat Enquiry</button>
        </form>
      </div>
    </section>

    <section class="page-section page-cta">
      <div>
        <p class="label">Location</p>
        <h2>Retreat by Upper Lough Erne</h2>
        <p>Shambala is based at <a href={mapsUrl} target="_blank" rel="noreferrer">48 Geaglum Road, Derrylin, Co. Fermanagh, BT92 9GN</a>.</p>
      </div>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/getting-here/">Plan Your Journey</a>
        <a class="btn btn-ghost btn-ghost--inverse" href="/retreats/">Explore All Retreats</a>
      </div>
    </section>

    <section class="page-section">
      <div class="section-heading">
        <div>
          <p class="label">Related Retreats</p>
          <h2>More Time at Shambala</h2>
        </div>
        <a class="btn btn-dark" href="/retreats/">View All Retreats</a>
      </div>
      <div class="related-retreats-grid">
        {relatedRetreats.map((item) => {
          const relatedSlug = item.data.slug ?? item.id.replace(/\.md$/, '');
          const relatedDate = item.data.startDate
            ? formatDate(item.data.startDate)
            : item.data.dateNote ?? (item.data.year ? `${item.data.year} date to confirm` : 'Date to confirm');
          const relatedPrice = item.data.priceEUR ? `£${item.data.price} / €${item.data.priceEUR}` : `£${item.data.price}`;
          return (
            <a class="related-retreat-card" href={`/retreats/${relatedSlug}/`}>
              <p class="label">{relatedDate} · {relatedPrice}</p>
              <h3>{item.data.title}</h3>
              <p>{item.data.description}</p>
              <span class="text-link">View retreat details</span>
            </a>
          );
        })}
      </div>
    </section>
  </article>
</BaseLayout>
