---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Corporate Wellness | Shambala Retreat Centre | Fermanagh',
  description: 'Plan corporate wellness and bespoke wellbeing events for businesses, schools, healthcare teams and groups with Shambala in Fermanagh and Northern Ireland.',
  canonical: 'https://shambalaholisticandretreatcentre.com/corporate-wellness/'
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Corporate Wellness Days in Northern Ireland',
  serviceType: 'Corporate wellness',
  provider: {
    '@type': 'HealthAndBeautyBusiness',
    name: 'Shambala Holistic & Retreat Centre'
  },
  areaServed: ['Northern Ireland', 'Ireland', 'Co. Fermanagh']
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--corporate">
    <div class="inner-hero__content">
      <p class="label">Teams · Schools · Healthcare · Groups</p>
      <h1>Corporate Wellness Days in Northern Ireland</h1>
      <p>Bespoke wellbeing events and retreats for groups who need practical tools for relaxation, stress management and reconnection.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Team Wellbeing</p>
        <h2>A Different Kind of Away Day</h2>
      </div>
      <div class="copy-flow">
        <p>Corporate and bespoke wellbeing events at Shambala focus on promoting relaxation, well-being and stress management.</p>
        <p>Sessions teach health and well-being skills and techniques that people can add to their own toolkit, whether as part of a staff training day, team building day, school programme or care setting visit.</p>
        <p>Shambala can come to you, arrange a venue, or host groups at Shambala Holistic Centre in Derrylin, Co. Fermanagh.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Who We Work With</p>
      <h2>Businesses, Schools, Healthcare and Care Settings</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Workplaces and Education</h3>
        <p>Businesses, groups, colleges, schools and universities.</p>
      </article>
      <article>
        <h3>Healthcare Settings</h3>
        <p>Health care organisations, hospitals, hospices and nursing homes.</p>
      </article>
      <article>
        <h3>Care and Support Groups</h3>
        <p>Day care centres, people with learning disabilities and their carers.</p>
      </article>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading section-heading--simple">
      <p class="label">Format</p>
      <h2>From 30 Minutes to Full Wellness Days</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>We Can Come to You</h3>
        <p>Shambala can deliver wellbeing sessions in your workplace, school, care setting or chosen venue.</p>
      </article>
      <article>
        <h3>Venue Hire</h3>
        <p>Shambala Holistic Centre is available as a hire venue for events by arrangement.</p>
      </article>
      <article>
        <h3>Flexible Length</h3>
        <p>Events can range from a 30-minute wellbeing session to full wellness days and can be incorporated into staff training and team building days.</p>
      </article>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Activities</p>
      <h2>Wellbeing Skills and Restorative Practices</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Massage</h3>
        <p>Massage can be included in bespoke wellbeing events by arrangement.</p>
      </article>
      <article>
        <h3>Reflexology</h3>
        <p>Reflexology is listed as an activity for corporate and bespoke wellbeing events.</p>
      </article>
      <article>
        <h3>Additional Activities</h3>
        <p class="card-note">TODO: Confirm the full corporate activities list with Sukhada before adding further options.</p>
      </article>
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Group Enquiry</p>
      <h2>Plan a Corporate Wellbeing Day</h2>
      <p>Contact Shambala to discuss your group, setting, preferred dates, timing and wellbeing goals.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="/contact/">Enquire About Corporate Days</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="/retreats/">Explore Retreats</a>
    </div>
  </section>
</BaseLayout>
