---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Corporate Wellness | Shambala Retreat Centre | Fermanagh',
  description: 'Plan corporate wellness and bespoke wellbeing events for businesses, schools, healthcare teams and groups with Shambala in Fermanagh and Northern Ireland.',
  canonical: 'https://shambalaholisticandretreatcentre.com/corporate-wellness/'
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Corporate Wellness Days in Northern Ireland',
  serviceType: 'Corporate wellness',
  provider: {
    '@type': 'HealthAndBeautyBusiness',
    name: 'Shambala Holistic & Retreat Centre'
  },
  areaServed: ['Northern Ireland', 'Ireland', 'Co. Fermanagh']
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--corporate">
    <div class="inner-hero__content">
      <p class="label">Teams · Schools · Healthcare · Groups</p>
      <h1>Corporate Wellness Days in Northern Ireland</h1>
      <p>Bespoke wellbeing events and retreats for groups who need practical tools for relaxation, stress management and reconnection.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Team Wellbeing</p>
        <h2>A Different Kind of Away Day</h2>
      </div>
      <div class="copy-flow">
        <p>Corporate and bespoke wellbeing events at Shambala focus on practical relaxation, wellbeing and stress management for teams, staff groups and care settings.</p>
        <p>Sessions can be shaped around staff training, team building, school programmes, healthcare teams or community groups, with activities adapted to suit individual needs.</p>
        <p>Shambala can come to you, arrange a venue, or host groups at Shambala Holistic & Retreat Centre in Derrylin, Co. Fermanagh.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Who We Work With</p>
      <h2>Businesses, Schools, Healthcare and Care Settings</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Workplaces and Education</h3>
        <p>Businesses, groups, colleges, schools and universities.</p>
      </article>
      <article>
        <h3>Healthcare Settings</h3>
        <p>Health care organisations, hospitals, hospices and nursing homes.</p>
      </article>
      <article>
        <h3>Care and Support Groups</h3>
        <p>Day care centres, people with learning disabilities and their carers.</p>
      </article>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading section-heading--simple">
      <p class="label">Format</p>
      <h2>From 30 Minutes to Full Wellness Days</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>We Can Come to You</h3>
        <p>Shambala can deliver wellbeing sessions in your workplace, school, care setting or chosen venue.</p>
      </article>
      <article>
        <h3>Venue Hire</h3>
        <p>Shambala Holistic & Retreat Centre is available as a hire venue for events by arrangement.</p>
      </article>
      <article>
        <h3>Flexible Length</h3>
        <p>Events can range from a 30-minute wellbeing session to full wellness days and can be incorporated into staff training and team building days.</p>
      </article>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Activities</p>
      <h2>Practical Wellbeing for Groups and Teams</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Mindfulness & Meditation</h3>
        <p>Grounding practices that help people pause, regulate and return to work with more steadiness.</p>
      </article>
      <article>
        <h3>EFT Tapping</h3>
        <p>Simple stress-management techniques that participants can continue using after the session.</p>
      </article>
      <article>
        <h3>Yoga & Sound Baths</h3>
        <p>Gentle movement and restorative sound work for relaxation, reset and shared calm.</p>
      </article>
      <article>
        <h3>Massage & Reflexology</h3>
        <p>Hands-on therapies can be included by arrangement for smaller groups or dedicated wellbeing days.</p>
      </article>
      <article>
        <h3>Chakra Dancing</h3>
        <p>Movement-based sessions that bring energy, confidence and connection into the room.</p>
      </article>
      <article>
        <h3>Life Coaching & CBT</h3>
        <p>Reflective tools for resilience, mindset and healthier patterns at work and in daily life.</p>
      </article>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Bespoke Events</p>
        <h2>Built Around Your People</h2>
        <p>Events can be as short as 30 minutes or expanded into a full wellness day, with options for workplace delivery, venue hire or a visit to Shambala.</p>
      </div>
      <div class="poster-preview-card">
        <a class="poster-preview-card__image" href="/retreat-posters/bespoke-wellness-events-corporate.png" target="_blank" rel="noreferrer" aria-label="Open bespoke wellness events poster">
          <img src="/retreat-posters/bespoke-wellness-events-corporate.png" alt="Bespoke wellness events poster for Shambala Holistic Retreat Centre, Derrylin, Co. Fermanagh" loading="lazy" />
        </a>
        <div class="poster-preview-card__actions">
          <a class="btn btn-dark" href="/retreat-posters/bespoke-wellness-events-corporate.png" target="_blank" rel="noreferrer">Open Poster</a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Group Enquiry</p>
      <h2>Plan a Corporate Wellbeing Day</h2>
      <p>Contact Shambala to discuss your group, setting, preferred dates, timing and wellbeing goals.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="/contact/">Enquire About Corporate Days</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="/retreats/">Explore Retreats</a>
    </div>
  </section>
</BaseLayout>
