---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Wellness Days Fermanagh & Cavan | Shambala Retreat Centre',
  description: 'Plan restorative wellness days with Shambala in Fermanagh and Cavan, with vegetarian lunch, gentle movement, sound bath and meditation.',
  canonical: 'https://shambalaholisticandretreatcentre.com/wellness-days/'
};

const cavanWellbeingDays = [
  ['Sun 23 August', 'Open to Joy', '/retreats/open-to-joy-wellbeing-day/'],
  ['Sat 12 September', 'Rooted & Radiant', '/retreats/rooted-and-radiant-wellbeing-day/'],
  ['Sat 17 October', 'Flow Within', '/retreats/flow-within-wellbeing-day/']
];

const halfDayRetreats = [
  ['Sun 28 June', 'Energy in Motion', '/retreats/energy-in-motion-wellbeing-day/'],
  ['Sun 26 July', 'Creative Flow', '/retreats/creative-flow-wellbeing-day/'],
  ['Sun 23 August', 'Yoga, Walking & Adventure', '/retreats/walking-nature-adventure-wellness-day/'],
  ['Sun 13 September', 'Journey Within', '/retreats/journey-within-silent-retreat/'],
  ['Sun 11 October', 'The Power of Manifestation', '/retreats/power-of-manifestation-wellbeing-day/'],
  ['Sun 15 November', 'Autumn Reset Wellbeing Day', '/retreats/relax-rewind-reset/']
];

const wellbeingDays2027 = [
  ['Sun 17 January 2027', 'Relax, Restore & Renew', '/retreats/relax-restore-renew-wellbeing-day/'],
  ['Sun 14 February 2027', 'Heart Awakening', '/retreats/heart-awakening-wellbeing-day/']
];

const dayRetreats = [
  ['Sat 27 June', 'Touching the Earth', '/retreats/touching-the-earth-half-day/'],
  ['Sat 29 August', 'Yoga Warrior', '/retreats/yoga-warrior-half-day/'],
  ['Sat 26 September', 'Life Purpose', '/retreats/ikigai-life-purpose-half-day/'],
  ['Sat 3 October', 'Joy', '/retreats/joy-day-retreat/'],
  ['Sat 31 October', 'Samhain & Shamanism', '/retreats/samhain-shamanism-half-day/']
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Wellness Days in Fermanagh and Cavan',
  serviceType: 'Wellness day',
  provider: {
    '@type': 'HealthAndBeautyBusiness',
    name: 'Shambala Holistic & Retreat Centre'
  }
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--wellness">
    <div class="inner-hero__content">
      <p class="label">Forest Bathing · Grounding · Meditation</p>
      <h1>Wellness Days in Fermanagh and Cavan</h1>
      <p>Half-day and full-day restorative experiences with Shambala, designed for rest, reconnection and natural balance.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Day Retreats</p>
        <h2>A Shorter Way to Step Away</h2>
      </div>
      <div class="copy-flow">
        <p>Wellness days with Shambala give you the feel of retreat without committing to a full residential weekend. They may include meditation, forest bathing, grounding practice, sound, gentle movement, lunch and quiet time.</p>
        <p>The current programme includes Sunday half-day retreats and Saturday day retreats, commonly running from either 12.30 pm-4.30 pm or 11.00 am-3.00 pm depending on the event.</p>
        <p>Most Shambala formats are listed at £40 with vegetarian lunch included. Energy in Motion and the Cavan wellbeing days are poster-listed at €50. Staying Saturday or Sunday night may be possible for Shambala-based dates at additional cost, subject to availability.</p>
        <p>Dates and availability change seasonally, so contact Sukhada before travelling.</p>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading section-heading--simple">
      <p class="label">Cavan Wellbeing Days · The Lab</p>
      <h2>Open to Joy, Rooted & Radiant, and Flow Within</h2>
      <p>Collaborative wellbeing days with Shambala and Zensational Wellbeing at The Lab, 65 Main St, Townparks, Cavan, H12 XC79. Vegetarian lunch included. €50 per person.</p>
    </div>
    <div class="programme-table-wrap">
      <table class="programme-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Theme</th>
          </tr>
        </thead>
        <tbody>
          {cavanWellbeingDays.map(([date, theme, href]) => (
            <tr>
              <td>{date}</td>
              <td><a href={href}>{theme}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Half-Day Retreats · Sundays</p>
      <h2>Sunday Wellbeing Days</h2>
      <p>Vegetarian lunch included. Most Sunday events run either 12.30 pm-4.30 pm or 11.00 am-3.00 pm; check each event page before travelling.</p>
    </div>
    <div class="programme-table-wrap">
      <table class="programme-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Theme</th>
          </tr>
        </thead>
        <tbody>
          {halfDayRetreats.map(([date, theme, href]) => (
            <tr>
              <td>{date}</td>
              <td><a href={href}>{theme}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading section-heading--simple">
      <p class="label">2027 Wellbeing Days</p>
      <h2>New Year and Heart-Centred Retreat Days</h2>
      <p>Poster-backed 2027 wellbeing dates currently listed by Shambala.</p>
    </div>
    <div class="programme-table-wrap">
      <table class="programme-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Theme</th>
          </tr>
        </thead>
        <tbody>
          {wellbeingDays2027.map(([date, theme, href]) => (
            <tr>
              <td>{date}</td>
              <td><a href={href}>{theme}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading section-heading--simple">
      <p class="label">Day Retreats · Saturdays</p>
      <h2>11.00 am-3.00 pm · £40 / €48</h2>
      <p>Vegetarian lunch included. Option to stay Saturday or Sunday night at additional cost, subject to availability.</p>
    </div>
    <div class="programme-table-wrap">
      <table class="programme-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Theme</th>
          </tr>
        </thead>
        <tbody>
          {dayRetreats.map(([date, theme, href]) => (
            <tr>
              <td>{date}</td>
              <td><a href={href}>{theme}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Featured Half-Day Retreats</p>
      <h2>Energy in Motion and Touching the Earth</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Energy in Motion</h3>
        <p>Give yourself a soft pause with Energy in Motion. This half-day experience invites you into a nurturing atmosphere of mindful presence, gentle movement and meditation.</p>
        <p>A beautiful way to soothe the nervous system, release stress and reconnect with your inner flow. No experience required. All welcome.</p>
      </article>
      <article>
        <h3>Touching the Earth</h3>
        <p>A grounding one-day retreat to reconnect with nature, quiet the mind and return to the present moment.</p>
        <p>The programme includes Hatha Yoga, Touching the Earth workshop, guided relaxation, lunch, barefoot grounding and Forest Bathing.</p>
      </article>
      <article>
        <h3>What to Expect</h3>
        <p>Programmes may include meditation, forest bathing, grounding practice, sound, gentle movement, lunch and quiet time by the water.</p>
      </article>
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Seasonal Dates</p>
      <h2>Plan Your Wellness Day at Shambala</h2>
      <p>Ask about upcoming half-day retreats, full wellness days, workshops and group availability.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="/contact/">Plan Your Wellness Day</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="/sound-baths-yoga/">Explore Sound & Yoga</a>
    </div>
  </section>
</BaseLayout>
