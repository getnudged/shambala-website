---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Wellness Days Fermanagh | Shambala Holistic Retreat Centre',
  description: 'Plan a wellness day in Fermanagh at Shambala, with forest bathing, meditation, grounding practices, gentle movement and lunch beside Upper Lough Erne.',
  canonical: 'https://shambalaholisticandretreatcentre.com/wellness-days/'
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Wellness Days in Fermanagh',
  serviceType: 'Wellness day',
  provider: {
    '@type': 'HealthAndBeautyBusiness',
    name: 'Shambala Holistic & Retreat Centre'
  }
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--wellness">
    <div class="inner-hero__content">
      <p class="label">Forest Bathing · Grounding · Meditation</p>
      <h1>Wellness Days in Fermanagh at Shambala</h1>
      <p>Half-day and full-day restorative experiences beside Upper Lough Erne, designed for rest, reconnection and natural balance.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Day Retreats</p>
        <h2>A Shorter Way to Step Away</h2>
      </div>
      <div class="copy-flow">
        <p>Wellness days at Shambala give you the feel of retreat without committing to a full residential weekend. They may include meditation, forest bathing, grounding practice, sound, gentle movement, lunch and quiet time by the water.</p>
        <p>The current programme includes half-day retreats and focused wellbeing days, with common half-day pricing listed at £40. Some specialist days may vary.</p>
        <p>Dates and availability change seasonally, so contact Sukhada before travelling.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">What to Expect</p>
      <h2>Restorative Ingredients</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Forest Bathing</h3>
        <p>Slow nature immersion in the grounds and nearby landscape, supporting presence and nervous system rest.</p>
      </article>
      <article>
        <h3>Grounding Practice</h3>
        <p>Simple practices that reconnect body, breath and attention, often using the lakeside setting.</p>
      </article>
      <article>
        <h3>Gentle Movement</h3>
        <p>Yoga, Tai Chi, Qigong or mindful movement depending on the focus of the day.</p>
      </article>
      <article>
        <h3>Meditation</h3>
        <p>Guided meditation and visualisation to support inner quiet and clarity.</p>
      </article>
      <article>
        <h3>Shared Lunch</h3>
        <p>Retreat-style food and time to pause between sessions.</p>
      </article>
      <article>
        <h3>Optional Therapies</h3>
        <p>Selected dates may include or offer optional holistic therapies by advance arrangement.</p>
      </article>
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Seasonal Dates</p>
      <h2>Plan Your Wellness Day at Shambala</h2>
      <p>Ask about upcoming half-day retreats, full wellness days and group availability.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="/contact/">Plan Your Wellness Day</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="/retreats/">Explore Retreats</a>
    </div>
  </section>
</BaseLayout>
