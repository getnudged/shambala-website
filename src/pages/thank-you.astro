---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Thank You | Shambala Holistic Retreat Centre | Fermanagh',
  description: 'Thank you for contacting Shambala Holistic & Retreat Centre in Derrylin, Co. Fermanagh. Sukhada will reply to your enquiry as soon as possible.',
  canonical: 'https://shambalaholisticandretreatcentre.com/thank-you/'
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Thank You for Contacting Shambala',
  url: meta.canonical
};
---

<BaseLayout {meta} {schema}>
  <section class="thank-you-page" aria-labelledby="thank-you-title">
    <div class="thank-you-page__inner">
      <p class="label">Enquiry Received</p>
      <h1 id="thank-you-title">Thank You for Contacting Shambala</h1>
      <p>Your message has been received. Sukhada will reply as soon as possible about your enquiry, retreat place, therapy booking or visit to Shambala.</p>
      <div class="thank-you-page__actions">
        <a class="btn btn-primary" href="/">Return to Shambala</a>
        <a class="btn btn-ghost" href="/retreats/">Explore Retreats</a>
      </div>
      <div class="thank-you-page__contact" aria-label="Direct contact details">
        <span>For urgent enquiries</span>
        <a href="https://wa.me/447713744589" target="_blank" rel="noreferrer">+44 7713 744 589</a>
        <a href="mailto:shambala108@icloud.com">shambala108@icloud.com</a>
      </div>
    </div>
  </section>
</BaseLayout>
