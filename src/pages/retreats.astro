---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Wellness Retreats Northern Ireland | Shambala Fermanagh',
  description: 'Explore 2026 wellness retreats at Shambala in Fermanagh, with yoga, sound baths, forest bathing, weekend retreats and half-day retreats by Lough Erne.',
  canonical: 'https://shambalaholisticandretreatcentre.com/retreats/'
};

const retreatCards = [
  {
    title: 'Yoga & Tai Chi Retreat',
    href: '/retreats/tai-chi-yoga-weekend/',
    type: 'Weekend retreat',
    date: '8-10 May 2026',
    price: '£260 / €300',
    summary: 'Relax and reconnect with a series of Yoga and Tai Chi classes during a weekend retreat beside Upper Lough Erne.',
    notes: 'Includes 2 nights accommodation, all vegetarian meals and activities.'
  },
  {
    title: 'Touching the Earth: A Grounding Retreat',
    href: '/retreats/touching-the-earth/',
    type: 'Weekend retreat',
    date: '26-28 June 2026',
    price: '£260 / €300',
    summary: 'Yoga, Tai Chi / Qigong, Meditation and Forest Bathing for grounding, earthing and reconnecting with nature.',
    notes: 'Includes 2 nights accommodation, all vegetarian meals and activities. Optional therapies available on request.'
  },
  {
    title: 'Yoga Warrior Weekend Retreat',
    href: '/retreats/yoga-warrior-weekend/',
    type: 'Weekend retreat',
    date: '28-30 August 2026',
    price: '£250 / €300',
    summary: 'A weekend of various yoga styles with nature walks, meditation, mindfulness, massages and sound bath.',
    notes: 'Source notes include tea/coffee and light vegetarian lunch; confirm whether this line applies to the full weekend or day retreat.'
  },
  {
    title: 'Life Purpose Weekend Retreat',
    href: '/retreats/ikigai-life-purpose-retreat/',
    type: 'Weekend retreat',
    date: '25-27 September 2026',
    price: '£250 / €300',
    summary: 'Introspection, meditation and relaxation with Ikigai, Wabi-Sabi, Kaizen, workshops, Tai Chi, Qigong, Yoga and Sound Bath.',
    notes: 'Source notes show £260 / €300 in one schedule and £250 / €300 in detail; using supplied detail price.'
  },
  {
    title: 'Flow Into Balance Weekend Retreat',
    href: '/retreats/flow-into-balance-weekend-retreat/',
    type: 'Weekend retreat',
    date: '2-4 October 2026',
    price: '£260 / €300',
    summary: 'A nurturing weekend to ground, align and restore with yoga, Chakra Dancing, guided relaxation, EFT, meditation and sound bath.',
    notes: 'Holistic therapy available to book separately.'
  },
  {
    title: 'Samhain & Shamanism Weekend Retreat',
    href: '/retreats/samhain-shamanism-weekend/',
    type: 'Weekend retreat',
    date: '30 October-1 November 2026',
    price: '£250 / €300',
    summary: 'Yoga, Chakra Dancing, shamanic practices, Cacao Ceremony, Fire Ceremony, sound bath meditation and nature connection.',
    notes: 'Therapy options available at additional cost; optional Sunday island programme noted on poster.'
  },
  {
    title: 'Wellness Days and Half-Day Retreats',
    href: '/wellness-days/',
    type: 'Half-day / wellbeing day',
    date: 'Multiple dates, year to confirm',
    price: 'Commonly £40',
    summary: 'Includes Inner Peace, Journey Within, Energy in Motion, Creative Flow, Walking Nature & Adventure, Autumn Reset and new 2027 wellbeing days.',
    notes: 'Most are £40 with vegetarian lunch included; check individual wellness day pages for exact poster-backed prices and times.'
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Wellness Retreats Northern Ireland at Shambala',
  url: meta.canonical,
  hasPart: {
    '@type': 'ItemList',
    itemListElement: retreatCards.map((retreat, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: retreat.title,
      description: retreat.summary
    }))
  }
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--retreats">
    <div class="inner-hero__content">
      <p class="label">2026 Retreat Programme · Upper Lough Erne</p>
      <h1>Wellness Retreats Northern Ireland at Shambala</h1>
      <p>Step away from daily life with residential weekend retreats, half-day retreats, sound baths and wellness days on the shores of Upper Lough Erne.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Retreat Overview</p>
        <h2>Time to Rest, Rebalance and Return to Yourself</h2>
      </div>
      <div class="copy-flow">
        <p>Shambala retreats bring together yoga, meditation, sound healing, forest bathing, mindful movement, nourishing food and optional holistic therapies in a peaceful lakeside setting in Derrylin, Co. Fermanagh.</p>
        <p>The current programme includes confirmed residential weekend retreats, plus half-day retreats, sound bath sessions and focused wellness days listed separately.</p>
        <p>For retreat information and booking, contact Sukhada by <a href="https://wa.me/447713744589" target="_blank" rel="noreferrer">Message on WhatsApp</a> or email <a href="mailto:shambala108@icloud.com">shambala108@icloud.com</a>.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Booking Notes</p>
      <h2>Deposits and Cancellation Policy</h2>
    </div>
    <div class="policy-grid">
      <article>
        <h3>Half-Day Retreat Deposit</h3>
        <p><strong>£20 / €23</strong> per person. Half-day retreats are commonly priced at £40.</p>
      </article>
      <article>
        <h3>Weekend Retreat Deposit</h3>
        <p><strong>£130 / €150</strong> per person. Weekend retreats are listed at £250-£260 / €300 depending on the retreat.</p>
      </article>
      <article>
        <h3>Cancellation Policy</h3>
        <p>Deposits are fully refundable up to 14 days before the retreat start date. After that, deposits can be transferred to a future retreat.</p>
      </article>
    </div>
    <p class="small-note">Deposits are described on the current site as optional, but priority is given to confirmed bookings with a deposit.</p>
  </section>

  <section class="page-section">
    <div class="section-heading">
      <div>
        <p class="label">2026 Programme</p>
        <h2>Weekend Retreats at Shambala</h2>
      </div>
      <a class="btn btn-dark" href="mailto:shambala108@icloud.com?subject=Retreat%20Enquiry">Enquire About Retreats</a>
    </div>

    <div class="retreat-index-grid">
      {retreatCards.map((retreat) => (
        <a class="retreat-index-card" href={retreat.href}>
          <p class="label">{retreat.type}</p>
          <h3>{retreat.title}</h3>
          <dl>
            <div>
              <dt>Date</dt>
              <dd>{retreat.date}</dd>
            </div>
            <div>
              <dt>Price</dt>
              <dd>{retreat.price}</dd>
            </div>
          </dl>
          <p>{retreat.summary}</p>
          <p class="card-note">{retreat.notes}</p>
          <span class="text-link">View retreat details</span>
        </a>
      ))}
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">No Modal Content</p>
      <h2>The Retreat Information Is Visible Here</h2>
      <p>The old site hides retreat details inside repeated pop-up modals. This index brings the programme into page content while the individual retreat pages are prepared in a later pass.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="https://wa.me/447713744589" target="_blank" rel="noreferrer">Message Sukhada</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="mailto:shambala108@icloud.com?subject=Retreat%20Enquiry">Email Shambala</a>
    </div>
  </section>
</BaseLayout>
