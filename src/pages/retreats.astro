---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEventDateLabel, getEventSlug, getEventTypeLabel, getPriceLabel, isResidentialRetreat, isUpcomingEvent, sortEventsByStartDate } from '../lib/events';
import '../styles/components/inner-pages.css';

const meta = {
  title: 'Wellness Retreats Northern Ireland | Shambala Fermanagh',
  description: 'Explore upcoming wellness retreats at Shambala in Fermanagh, with yoga, sound baths, forest bathing, weekend retreats and half-day retreats by Lough Erne.',
  canonical: 'https://shambalaholisticandretreatcentre.com/retreats/'
};

const allEvents = await getCollection('retreats');
const retreatCards = sortEventsByStartDate(allEvents.filter((event) => isUpcomingEvent(event) && isResidentialRetreat(event)));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Wellness Retreats Northern Ireland at Shambala',
  url: meta.canonical,
  hasPart: {
    '@type': 'ItemList',
    itemListElement: retreatCards.map((retreat, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: retreat.data.title,
      description: retreat.data.description,
      url: `https://shambalaholisticandretreatcentre.com/retreats/${getEventSlug(retreat)}/`
    }))
  }
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--retreats">
    <div class="inner-hero__content">
      <p class="label">Upcoming Retreat Programme · Upper Lough Erne</p>
      <h1>Wellness Retreats Northern Ireland at Shambala</h1>
      <p>Step away from daily life with residential weekend retreats, half-day retreats, sound baths and wellness days on the shores of Upper Lough Erne.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Retreat Overview</p>
        <h2>Time to Rest, Rebalance and Return to Yourself</h2>
      </div>
      <div class="copy-flow">
        <p>Shambala retreats bring together yoga, meditation, sound healing, forest bathing, mindful movement, nourishing food and optional holistic therapies in a peaceful lakeside setting in Derrylin, Co. Fermanagh.</p>
        <p>The current programme is now powered by the retreat content files, so newly published residential retreats can appear here automatically while past events drop away from the public listing.</p>
        <p>For retreat information and booking, contact Sukhada by <a href="https://wa.me/447713744589" target="_blank" rel="noreferrer">Message on WhatsApp</a> or email <a href="mailto:shambala108@icloud.com">shambala108@icloud.com</a>.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Booking Notes</p>
      <h2>Deposits and Cancellation Policy</h2>
    </div>
    <div class="policy-grid">
      <article>
        <h3>Half-Day Retreat Deposit</h3>
        <p><strong>£20 / €23</strong> per person. Half-day retreats are commonly priced at £40.</p>
      </article>
      <article>
        <h3>Weekend Retreat Deposit</h3>
        <p><strong>£130 / €150</strong> per person. Weekend retreats are listed at £250-£260 / €300 depending on the retreat.</p>
      </article>
      <article>
        <h3>Cancellation Policy</h3>
        <p>Deposits are fully refundable up to 14 days before the retreat start date. After that, deposits can be transferred to a future retreat.</p>
      </article>
    </div>
    <p class="small-note">Deposits are described on the current site as optional, but priority is given to confirmed bookings with a deposit.</p>
  </section>

  <section class="page-section">
    <div class="section-heading">
      <div>
        <p class="label">Upcoming Programme</p>
        <h2>Weekend Retreats at Shambala</h2>
      </div>
      <a class="btn btn-dark" href="mailto:shambala108@icloud.com?subject=Retreat%20Enquiry">Enquire About Retreats</a>
    </div>

    <div class="retreat-index-grid">
      {retreatCards.map((retreat) => (
        <a class="retreat-index-card" href={`/retreats/${getEventSlug(retreat)}/`}>
          <p class="label">{getEventTypeLabel(retreat)}</p>
          <h3>{retreat.data.title}</h3>
          <dl>
            <div>
              <dt>Date</dt>
              <dd>{getEventDateLabel(retreat, true)}</dd>
            </div>
            <div>
              <dt>Price</dt>
              <dd>{getPriceLabel(retreat)}</dd>
            </div>
          </dl>
          <p>{retreat.data.description}</p>
          {retreat.data.bookingNote && <p class="card-note">{retreat.data.bookingNote}</p>}
          {!retreat.data.bookingNote && retreat.data.includes.length > 0 && <p class="card-note">{retreat.data.includes.slice(0, 3).join(' · ')}</p>}
          <span class="text-link">View retreat details</span>
        </a>
      ))}
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Wellness Days</p>
      <h2>Looking for Shorter Retreat Days?</h2>
      <p>Half-day retreats, wellbeing days and workshops are listed separately so they stay easy to scan.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="/wellness-days/">View Wellness Days</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="https://wa.me/447713744589" target="_blank" rel="noreferrer">Message Sukhada</a>
    </div>
  </section>
</BaseLayout>
