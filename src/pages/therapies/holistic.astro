---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/components/inner-pages.css';

const meta = {
  title: 'Reiki and Holistic Therapies | Shambala Holistic Retreat Centre',
  description: 'Book 60 minute holistic therapies in Fermanagh with Sukhada at Shambala, including Access Bars, Alchemy Healing, EFT and Flower Essences.',
  canonical: 'https://shambalaholisticandretreatcentre.com/therapies/holistic/'
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Reiki and Holistic Therapies in Fermanagh',
  serviceType: 'Holistic therapy',
  provider: {
    '@type': 'HealthAndBeautyBusiness',
    name: 'Shambala Holistic & Retreat Centre'
  }
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--holistic">
    <div class="inner-hero__content">
      <p class="label">Reiki · EFT · Reflexology · Crystal Healing</p>
      <h1>Reiki and Holistic Therapies in Fermanagh</h1>
      <p>Gentle, individual therapies with Sukhada for relaxation, self-healing and natural balance.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="split-layout">
      <div>
        <p class="label">Holistic Care</p>
        <h2>Natural, Non-Invasive Support</h2>
      </div>
      <div class="copy-flow">
        <p>Holistic therapy at Shambala looks at the whole person. Sessions are calm, individual and designed to support relaxation, confidence, stress reduction and the body's natural capacity for balance.</p>
        <p>Sukhada has practised holistic therapies since 1999 and welcomes people for one-off support, regular care, retreat add-ons and deeper Reiki pathways.</p>
        <p>Confirmed holistic therapy sessions are 60 minutes and listed at £35.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="section-heading section-heading--simple">
      <p class="label">Available Therapies</p>
      <h2>60 Minute Sessions · £35</h2>
    </div>
    <div class="value-grid">
      <article>
        <h3>Access Bars</h3>
        <p>A body process for change which involves touching different points on the head. Releases anxiety, stress and negative emotions.</p>
      </article>
      <article>
        <h3>Alchemy Healing</h3>
        <p>Involves the use of Flower Essences to balance the body.</p>
      </article>
      <article>
        <h3>Energetic Family Healing</h3>
        <p>A gentle therapeutic practice supporting the release of inherited emotional patterns and restoring balance across generations.</p>
      </article>
      <article>
        <h3>EFT Tapping</h3>
        <p>Emotional Freedom Technique involves tapping on specific acupressure points while focusing on a particular issue or emotion.</p>
      </article>
      <article>
        <h3>Flower Essences Practitioner Sessions</h3>
        <p>Natural vibrational remedies supporting emotional balance, stress relief and inner wellbeing.</p>
      </article>
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Therapy Enquiry</p>
      <h2>Ask Sukhada Which Therapy Is Right for You</h2>
      <p>Use the contact page to enquire about availability and the best session for your needs.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="/contact/">Book a Holistic Therapy</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="/therapies/massage/">Explore Massage</a>
    </div>
  </section>
</BaseLayout>
