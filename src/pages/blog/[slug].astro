---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/components/inner-pages.css';

const blogImages = import.meta.glob('../../images/*.{jpg,jpeg,png,webp}', {
  eager: true,
  import: 'default'
}) as Record<string, ImageMetadata>;

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postSlug = post.id.replace(/\.md$/, '');
const postImage = post.data.image ? blogImages[`../../images/${post.data.image}`] : undefined;
const postImageSrc = typeof postImage === 'object' && postImage !== null && 'src' in postImage ? postImage.src : undefined;
const postImageAlt = post.data.imageAlt ?? `${post.data.title} at Shambala Holistic Retreat Centre, Derrylin, Co. Fermanagh`;

const canonical = `https://shambalaholisticandretreatcentre.com/blog/${postSlug}/`;

const meta = {
  title: post.data.seoTitle ?? `${post.data.title} | Shambala Holistic Retreat Centre | Fermanagh`,
  description: post.data.description,
  canonical,
  image: postImageSrc ? `https://shambalaholisticandretreatcentre.com${postImageSrc}` : undefined
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.pubDate.toISOString(),
  url: canonical,
  image: postImageSrc ? `https://shambalaholisticandretreatcentre.com${postImageSrc}` : undefined,
  author: {
    '@type': 'Organization',
    name: 'Shambala Holistic & Retreat Centre'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Shambala Holistic & Retreat Centre'
  },
  mainEntityOfPage: canonical
};
---

<BaseLayout {meta} {schema}>
  <article>
    <header class="inner-hero inner-hero--blog-post">
      <div class="inner-hero__content">
        <p class="label">
          {post.data.pubDate.toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'long',
            year: 'numeric'
          })}
        </p>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </div>
    </header>

    <section class="page-section">
      <div class="article-layout">
        <aside class="article-meta" aria-label="Article details">
          <p class="label">Topics</p>
          <ul>
            {post.data.keywords.map((keyword: string) => <li>{keyword}</li>)}
          </ul>
          <a class="btn btn-dark" href="/blog/">Back to Blog</a>
        </aside>
        <div class="article-content">
          {postImage && (
            <figure class="blog-post-image">
              <Image src={postImage} alt={postImageAlt} loading="eager" />
            </figure>
          )}
          <Content />
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
