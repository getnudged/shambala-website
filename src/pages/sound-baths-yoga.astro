---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/components/inner-pages.css';
import soundImage from '../images/benefits-of-a-sound-bath.png';
import yogaImage from '../images/shambala-retreat-yoga-warrior-fermanagh.png';

const meta = {
  title: 'Sound Baths and Yoga | Shambala Holistic Retreat Centre | Fermanagh',
  description: 'Explore sound baths and yoga at Shambala in Derrylin, Co. Fermanagh, with dedicated pages for sound meditation, yoga classes and retreat sessions.',
  canonical: 'https://shambalaholisticandretreatcentre.com/sound-baths-yoga/'
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Sound Baths and Yoga in Fermanagh',
  serviceType: 'Sound bath meditation and yoga classes',
  provider: {
    '@type': 'HealthAndBeautyBusiness',
    name: 'Shambala Holistic & Retreat Centre'
  },
  areaServed: ['Derrylin', 'Co. Fermanagh', 'Enniskillen', 'Northern Ireland']
};
---

<BaseLayout {meta} {schema}>
  <section class="inner-hero inner-hero--sound">
    <div class="inner-hero__content">
      <p class="label">Sound Healing · Yoga · Meditation</p>
      <h1>Sound Baths and Yoga at Shambala</h1>
      <p>Two restorative ways to soften the body, quiet the mind and reconnect beside Upper Lough Erne.</p>
    </div>
  </section>

  <section class="page-section">
    <div class="section-heading section-heading--simple">
      <p class="label">Choose Your Session</p>
      <h2>Sound Stillness or Gentle Movement</h2>
    </div>
    <div class="pathway-grid">
      <a class="pathway-card pathway-card--image" href="/sound-baths/">
        <Image src={soundImage} alt="Sound bath meditation at Shambala Holistic Retreat Centre, Derrylin, Co. Fermanagh" loading="lazy" />
        <div>
          <p class="label">Sound Baths</p>
          <h3>Rest deeply with bowls, gong and sound meditation</h3>
          <span class="text-link">Book a sound bath</span>
        </div>
      </a>
      <a class="pathway-card pathway-card--image" href="/yoga/">
        <Image src={yogaImage} alt="Yoga retreat session at Shambala Holistic Retreat Centre, Derrylin, Co. Fermanagh" loading="lazy" />
        <div>
          <p class="label">Yoga</p>
          <h3>Join weekly classes and retreat yoga with Shambala</h3>
          <span class="text-link">View yoga classes</span>
        </div>
      </a>
    </div>
  </section>

  <section class="page-section page-section--mist">
    <div class="split-layout">
      <div>
        <p class="label">At Shambala</p>
        <h2>Practices That Work Beautifully Together</h2>
      </div>
      <div class="copy-flow">
        <p>Sound baths and yoga are offered separately, and often appear together within retreats, wellness days and special evening sessions at Shambala Holistic & Retreat Centre.</p>
        <p>Yoga helps the body arrive through breath and movement. Sound bath meditation then invites the nervous system towards stillness through resonant tones and deep listening.</p>
        <p>Both pages include booking details, what to expect and the best next step for first-time visitors.</p>
      </div>
    </div>
  </section>

  <section class="page-section page-cta">
    <div>
      <p class="label">Booking</p>
      <h2>Ask About Sound Baths or Yoga</h2>
      <p>Contact Sukhada for current dates, weekly yoga classes, private group sessions and retreat availability.</p>
    </div>
    <div class="cta-actions">
      <a class="btn btn-primary" href="https://wa.me/447713744589" target="_blank" rel="noreferrer">Message to Book</a>
      <a class="btn btn-ghost btn-ghost--inverse" href="/contact/">Contact Shambala</a>
    </div>
  </section>
</BaseLayout>
